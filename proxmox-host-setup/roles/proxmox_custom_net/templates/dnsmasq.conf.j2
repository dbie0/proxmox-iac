interface=br_trs_sep
interface=br_trs
no-dhcp-interface=br_trs
domain={{ proxmox_custom_net_dnsmasq_domain }}
dhcp-authoritative
local-ttl=0
# Issue IPs to VMs
dhcp-range=interface:br_trs_sep,{{ proxmox_custom_net_dnsmasq_range }}
# Define the router and main DNS server for the VMs
dhcp-option=option:router,{{ proxmox_custom_net_dnsmasq_router }}
dhcp-option=option:dns-server,{{ proxmox_custom_net_dnsmasq_dns }}